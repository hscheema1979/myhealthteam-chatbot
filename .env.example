# MyHealthTeam Chatbot Environment Configuration
# Copy this file to .env and configure for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# IMPORTANT: This should ALWAYS point to a TEST database, never production
DATABASE_PATH=/home/ubuntu/myhealthteam-chatbot/production_backup_for_testing.db

# ============================================================================
# GEMINI CLI CONFIGURATION
# ============================================================================
# Gemini model to use (gemini-pro, gemini-ultra, etc.)
GEMINI_MODEL=gemini-pro

# Timeout for Gemini CLI subprocess (milliseconds)
GEMINI_TIMEOUT=30000

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Port for Streamlit server (default: 8502, separate from main app on 8501)
CHATBOT_PORT=8502

# Host to bind to (0.0.0.0 for all interfaces, localhost for local only)
CHATBOT_HOST=0.0.0.0

# ============================================================================
# SECURITY
# ============================================================================
# Secret key for session encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-secret-key

# Session timeout in seconds (default: 1 hour)
SESSION_TIMEOUT=3600

# ============================================================================
# LOGGING
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=/var/log/myhealthteam-chatbot/chatbot.log

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Enable debug mode (shows detailed errors, auto-reload on code changes)
DEBUG=false

# Enable file watcher for auto-reload (dev only)
ENABLE_FILE_WATCHER=false
